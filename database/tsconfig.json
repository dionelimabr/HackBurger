{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "typeRoots": ["../backend/node_modules/@types"],
    "baseUrl": ".",
    "paths": {
      "*": ["../backend/node_modules/*"]
    },
    "noEmit": true
  },
  "include": ["**/*.ts"],
  "exclude": ["../node_modules"]
}
